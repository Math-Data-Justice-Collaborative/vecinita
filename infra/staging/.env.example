# Staging connectivity env (H4–H5) — copy into prod.env or export before operator smokes.
#
# Used by: scripts/deploy/verify_connectivity.sh, scripts/deploy/staging_smoke.sh
# See: docs/staging-runbook.md
#
# These are read URLs for smoke tests — not pushed to GitHub/DO/Modal secrets.
# API secrets (DATABASE_URL, VECINITA_INTERNAL_API_KEY) live in infra/github/.env.example.

# API liveness + RAG smoke (H1, H3, H4)
VECINITA_STAGING_CHAT_URL=https://vecinita-chat-rag-backend-<id>.ondigitalocean.app

# Internal write API (H1 optional, H4, H5)
VECINITA_STAGING_WRITE_URL=https://vecinita-internal-write-api-<id>.ondigitalocean.app

# Static frontends — required for live CORS preflight + bundle wiring (H4, H5)
VECINITA_STAGING_CHAT_FRONTEND_URL=https://vecinita-chat-rag-frontend-<id>.ondigitalocean.app
VECINITA_STAGING_ADMIN_FRONTEND_URL=https://vecinita-admin-frontend-<id>.ondigitalocean.app

# Modal data-management jobs API (H4 admin CORS)
VECINITA_STAGING_ADMIN_API_URL=https://vecinita--vecinita-data-management-fastapi-app.modal.run

# Database readiness (H2) — falls back to DATABASE_URL when unset
# VECINITA_STAGING_DATABASE_URL=postgresql://doadmin:<password>@<host>:25060/defaultdb?sslmode=require

# EV-002 admin integration smokes (optional)
# VECINITA_STAGING_INTERNAL_API_KEY=<same-as-VECINITA_INTERNAL_API_KEY>

# Run locally (skips live tiers when all URLs unset — exit 0):
#   bash scripts/deploy/verify_connectivity.sh
# Or: make verify-connectivity
