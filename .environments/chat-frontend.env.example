# Chat frontend — minimal `VITE_*` overrides.
# Canonical environment catalog: repo root .env.example
#
# Prefer `VITE_GATEWAY_URL=/api` when using the Vite dev proxy (see vite.config.ts).

VITE_GATEWAY_URL=/api
VITE_GATEWAY_PROXY_TARGET=http://127.0.0.1:8004
VITE_AGENT_REQUEST_TIMEOUT_MS=90000
VITE_AGENT_STREAM_TIMEOUT_MS=120000
VITE_AGENT_STREAM_FIRST_EVENT_TIMEOUT_MS=15000
VITE_ADMIN_AUTH_ENABLED=true
VITE_ADMIN_EMAIL=
VITE_ADMIN_PASSWORD=
VITE_ADMIN_TOKEN=
