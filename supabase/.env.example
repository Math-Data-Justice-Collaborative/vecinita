# Supabase CLI / config-push — environment (EXAMPLE / placeholders only)
#
# Best practices (Supabase):
#   - Keep migrations and auth config in git; apply via CLI, not Dashboard edits.
#   - Store SUPABASE_ACCESS_TOKEN + passwords as GitHub encrypted secrets (never in repo).
#   - Use `supabase config push` for auth URLs, SMTP, and email templates (ADR-027/030).
#   - Use `supabase db push` for SQL migrations in supabase/migrations/.
#   - CI: supabase.yml + deploy-modal.yml run sync-production on main.
#   - Required CI vars: SUPABASE_ACCESS_TOKEN, SUPABASE_DB_PASSWORD, SUPABASE_PROJECT_ID
#     (see https://supabase.com/docs/guides/deployment/managing-environments)
#
# Local / operator workflow:
#
#   set -a && source prod.env && set +a
#   export SUPABASE_DB_PASSWORD="${SUPABASE_DATABASE_PASSWORD:-$SUPABASE_DB_PASSWORD}"
#   bash scripts/supabase/ci_sync.sh sync-production
#
# Resend SMTP credential: see infra/resend/.env.example (SUPABASE_SMTP_PASS = Resend API key)
# Matrix: docs/staging-secrets-matrix.md §Supabase project
# NEVER commit real secrets to git.

# ---------------------------------------------------------------------------
# CLI authentication + project link
# ---------------------------------------------------------------------------
SUPABASE_ACCESS_TOKEN=sbp_<personal-access-token>   # https://supabase.com/dashboard/account/tokens
SUPABASE_PROJECT_ID=cfuvghdsuwactfeamtym            # canonical project ref
SUPABASE_URL=https://cfuvghdsuwactfeamtym.supabase.co

# prod.env may use SUPABASE_DATABASE_PASSWORD; CLI and supabase.yml expect SUPABASE_DB_PASSWORD:
#   export SUPABASE_DB_PASSWORD="${SUPABASE_DATABASE_PASSWORD}"
SUPABASE_DB_PASSWORD=<supabase-db-password>

# ---------------------------------------------------------------------------
# API keys (server-side scripts + browser publishable key for admin frontend build)
# ---------------------------------------------------------------------------
SUPABASE_SECRET_KEY=sb_secret_<secret-key>           # Modal DM only at runtime — never VITE_*
SUPABASE_PUBLISHABLE_KEY=sb_publishable_<publishable-key>

# First-admin bootstrap (operator scripts — not required for config push)
SUPABASE_ADMIN_EMAIL=admin@vecinita.admin
SUPABASE_ADMIN_PASSWORD=<strong-password>

# ---------------------------------------------------------------------------
# EV-006 (F35) — Resend SMTP for Supabase Auth emails
# Resolved at `config push`: [auth.email.smtp] pass = env(SUPABASE_SMTP_PASS)
# Full Resend setup: infra/resend/.env.example
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_<resend-api-key>
RESEND_SENDER_EMAIL=noreply@josephcmcg.com          # must match supabase/config.toml admin_email
SUPABASE_SMTP_PASS=re_<resend-api-key>              # same value as RESEND_API_KEY
