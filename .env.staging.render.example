# Shared Render staging environment contract template
# Key set must stay in parity with .env.prod.render.example

ALLOWED_ORIGINS=https://vecinita-frontend-staging.onrender.com
CORS_ORIGINS=https://vecinita-data-management-frontend-v1-staging.onrender.com
DATABASE_URL=postgresql://user:password@host:5432/db?sslmode=require
DB_DATA_MODE=postgres
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
EMBEDDING_SERVICE_AUTH_TOKEN=replace-me
GROQ_API_KEY=
MODAL_TOKEN_ID=replace-me
MODAL_TOKEN_SECRET=replace-me
MODAL_FUNCTION_INVOCATION=auto
MODAL_WORKSPACE=vecinita
# Gateway + Modal secret vecinita-scraper-env: same semantics (gateway-owned control plane).
MODAL_SCRAPER_PERSIST_VIA_GATEWAY=1
OLLAMA_MODEL=gemma3
OPENAI_API_KEY=
RENDER_REMOTE_INFERENCE_ONLY=true
# Comma-separated Bearer secrets for the scraper HTTP API. Replace for real staging.
SCRAPER_API_KEYS=render-contract-example-key-alpha,render-contract-example-key-bravo
# See .env.prod.render.example for embedding URL notes (canonical Modal web_app host).
VECINITA_EMBEDDING_API_URL=https://vecinita--vecinita-embedding-web-app.modal.run
VECINITA_MODEL_API_URL=https://vecinita--vecinita-model-api.modal.run
VECINITA_SCRAPER_API_URL=https://vecinita--vecinita-scraper-api-fastapi.modal.run/jobs
# Optional HTTP-mode fallback only. Leave empty when using Modal function invocation.
REINDEX_SERVICE_URL=
REINDEX_TRIGGER_TOKEN=
# vecinita-gateway: omit on Render — render.yaml injects AGENT_SERVICE_URL via fromService (host:port).
# For local CLI/tests, set in .env e.g. AGENT_SERVICE_URL=http://localhost:8000 (see .env.local.example).
# Optional overrides for slow agent cold starts (seconds).
AGENT_TIMEOUT=180
AGENT_STREAM_TIMEOUT=180
VITE_BACKEND_URL=https://vecinita-gateway-staging.onrender.com/api/v1
VITE_DEFAULT_SCRAPER_USER_ID=frontend-user
VITE_GATEWAY_URL=https://vecinita-gateway-staging.onrender.com/api/v1
VITE_VECINITA_SCRAPER_API_URL=https://vecinita-data-management-api-v1-staging.onrender.com
