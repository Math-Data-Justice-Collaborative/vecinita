  "info": {
    "description": "Serverless web scraping pipeline with job queue management",
    "title": "Vecinita Scraper",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/": {
      "get": {
        "description": "Public landing; job routes still need ``Authorization: Bearer``.",
        "operationId": "root__get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
