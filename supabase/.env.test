# Local Test Environment Variables
# Safe to commit - contains NO production secrets

# ---------------------------------
# Local Supabase (Test Only)
# ---------------------------------
SUPABASE_URL=http://localhost:3001
SUPABASE_KEY=test-anon-key-local-development-only

# ---------------------------------
# Local Database (Test Only)
# ---------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:54321/postgres

# ---------------------------------
# API Keys (Use test/dummy keys for local testing)
# Real keys should be in root .env file (gitignored)
# ---------------------------------
GROQ_API_KEY=test-key-replace-for-real-testing
DEEPSEEK_API_KEY=test-key-replace-for-real-testing
OPEN_API_KEY=test-key-replace-for-real-testing
TAVILY_API_KEY=test-key-replace-for-real-testing

# ---------------------------------
# Agent Configuration
# ---------------------------------
DEFAULT_PROVIDER=deepseek

# ---------------------------------
# Embedding Configuration
# ---------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
USE_LOCAL_EMBEDDINGS=true

# ---------------------------------
# LangSmith (Disabled for local testing)
# ---------------------------------
LANGSMITH_TRACING=false

# ---------------------------------
# TensorFlow Configuration
# ---------------------------------
TF_ENABLE_ONEDNN_OPTS=0
