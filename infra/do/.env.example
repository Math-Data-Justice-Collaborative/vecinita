# DigitalOcean App Platform — environment variables (EXAMPLE / placeholders only)
#
# Best practices (DigitalOcean App Platform):
#   - Mark sensitive values as type SECRET in infra/do/*.yaml (encrypted at rest as EV[...]).
#   - Use scope BUILD_TIME for VITE_* on static sites; RUN_TIME for backends.
#   - After changing BUILD_TIME vars, redeploy the static site (secret sync alone is not enough).
#   - DATABASE_URL must include ?sslmode=require for Managed Postgres.
#   - sync-secrets reads the LIVE spec and preserves existing encrypted keys (do_apps.py).
#   - CI/CD: deploy-digitalocean.yml runs Alembic + sync-all-secrets before redeploy.
#
# Copy to prod.env (gitignored) and push:
#
#   set -a && source prod.env && set +a
#   export DIGITALOCEAN_TOKEN='dop_v1_...'
#   uv run --with pydo --with pyyaml scripts/deploy/do_apps.py sync-all-secrets
#   uv run --with pydo --with pyyaml scripts/deploy/do_apps.py deploy --name vecinita-admin-frontend
#
# Or: bash scripts/deploy/sync_env.sh --do --apply
#
# Spec shapes: infra/do/*.yaml
# Matrix: docs/staging-secrets-matrix.md
# NEVER commit real secrets to git.

# ---------------------------------------------------------------------------
# pydo / do_apps.py (operator shell — not an app runtime var)
# ---------------------------------------------------------------------------
DIGITALOCEAN_TOKEN=dop_v1_<your-do-api-token>

# ---------------------------------------------------------------------------
# Shared — Managed Postgres (both backends) + CI Alembic
# Run once per schema change: bash scripts/deploy/ci_alembic_upgrade.sh
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://doadmin:<password>@<host>:25060/defaultdb?sslmode=require

# ---------------------------------------------------------------------------
# vecinita-internal-write-api  (RUN_TIME — infra/do/internal-write-api.yaml)
# ---------------------------------------------------------------------------
VECINITA_INTERNAL_API_KEY=<random-bearer-token-for-modal-and-legacy-clients>
VECINITA_CORS_ORIGINS=https://vecinita-admin-frontend-<id>.ondigitalocean.app,https://vecinita-chat-rag-frontend-<id>.ondigitalocean.app
VECINITA_MODAL_DATA_MGMT_URL=https://vecinita--vecinita-data-management-fastapi-app.modal.run
VECINITA_MODAL_PROXY_KEY=<same-as-modal-secret-and-vite-modal-proxy-key>
VECINITA_MODAL_EMBED_URL=https://vecinita--vecinita-embedding-embedding-api.modal.run
VECINITA_MODAL_LLM_URL=https://vecinita--vecinita-llm-fastapi-app.modal.run
VECINITA_CHAT_RAG_URL=https://vecinita-chat-rag-backend-<id>.ondigitalocean.app
VECINITA_CHAT_FRONTEND_URL=https://vecinita-chat-rag-frontend-<id>.ondigitalocean.app
VECINITA_ADMIN_FRONTEND_URL=https://vecinita-admin-frontend-<id>.ondigitalocean.app
VECINITA_HEALTH_TIMEOUT_MS=5000
VECINITA_AUDIT_RETENTION_DAYS=365
VECINITA_ENV=staging

# EV-005 F34 — Supabase JWT verification (ES256/JWKS from SUPABASE_URL; ADR-028)
SUPABASE_URL=https://<project-ref>.supabase.co
VECINITA_AUTH_REQUIRED=true
# SUPABASE_JWT_AUD=authenticated

# EV-006: SUPABASE_SECRET_KEY does NOT belong on DigitalOcean (Modal DM only — ADR-030).

# ---------------------------------------------------------------------------
# vecinita-chat-rag-backend  (RUN_TIME — infra/do/chat-rag-backend.yaml)
# ChatRAG stays anonymous — no Supabase auth vars on this app (ADR-026).
# ---------------------------------------------------------------------------
# DATABASE_URL=                    # same Managed Postgres as write API
# VECINITA_MODAL_EMBED_URL=
# VECINITA_MODAL_LLM_URL=
# VECINITA_CORS_ORIGINS=https://vecinita-chat-rag-frontend-<id>.ondigitalocean.app
# VECINITA_INTERNAL_WRITE_URL=https://vecinita-internal-write-api-<id>.ondigitalocean.app
# VECINITA_INTERNAL_API_KEY=       # must match write API
# VECINITA_STATS_ENABLED=true

# ---------------------------------------------------------------------------
# vecinita-admin-frontend  (BUILD_TIME — infra/do/data-management-frontend.yaml)
# Rebuild required after any VITE_* change.
# ---------------------------------------------------------------------------
VITE_VECINITA_ADMIN_API_URL=https://vecinita--vecinita-data-management-fastapi-app.modal.run
VITE_VECINITA_MODAL_PROXY_KEY=<same-as-VECINITA_MODAL_PROXY_KEY>
VITE_VECINITA_CORPUS_API_URL=https://vecinita-internal-write-api-<id>.ondigitalocean.app
# Legacy local-dev fallback; production prefers Supabase JWT from browser session:
VITE_VECINITA_CORPUS_API_KEY=<same-as-VECINITA_INTERNAL_API_KEY>
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-publishable-key>

# ---------------------------------------------------------------------------
# vecinita-chat-rag-frontend  (BUILD_TIME — infra/do/chat-rag-frontend.yaml)
# ---------------------------------------------------------------------------
VITE_VECINITA_CHAT_API_URL=https://vecinita-chat-rag-backend-<id>.ondigitalocean.app
