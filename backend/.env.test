# Test Environment Configuration
# Copy this to backend/.env when running local tests
# For production, use the root .env file with real credentials

# ---------------------------------
# Local Test Supabase
# ---------------------------------
SUPABASE_URL=http://localhost:3001
SUPABASE_KEY=test-anon-key-local-development-only
DATABASE_URL=postgresql://postgres:postgres@localhost:54321/postgres

# ---------------------------------
# Database Credentials (Local Test)
# ---------------------------------
DB_HOST=localhost
DB_PORT=54321
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# ---------------------------------
# Cloud LLM Provider API Keys
# ⚠️ IMPORTANT: Replace with your real keys for testing
# Or copy from root .env file (which is gitignored)
# ---------------------------------
DEEPSEEK_API_KEY=your-real-deepseek-key-here
GROQ_API_KEY=your-real-groq-key-here
OPEN_API_KEY=your-real-openai-key-here
TAVILY_API_KEY=your-real-tavily-key-here

# ---------------------------------
# Agent Provider Configuration
# ---------------------------------
DEFAULT_PROVIDER=deepseek

# ---------------------------------
# Embedding Model Config
# ---------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
USE_LOCAL_EMBEDDINGS=true

# ---------------------------------
# LangSmith (Optional for testing)
# ---------------------------------
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=local-testing

# ---------------------------------
# TensorFlow Configuration
# ---------------------------------
TF_ENABLE_ONEDNN_OPTS=0

# ---------------------------------
# HuggingFace (Optional)
# ---------------------------------
HUGGINGFACE_ACCESS_TOKEN=
