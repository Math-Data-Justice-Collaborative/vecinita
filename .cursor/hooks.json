{
  "$schema": "https://unpkg.com/cursor-hooks@latest/schema/hooks.schema.json",
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": "uv run python .cursor/hooks/scope_check.py",
        "matcher": "Write",
        "timeout": 10
      },
      {
        "command": "uv run python .cursor/hooks/pre_task_check.py",
        "matcher": "Write",
        "timeout": 10
      },
      {
        "command": "uv run python .cursor/hooks/pr_checklist.py",
        "matcher": "Shell",
        "timeout": 10
      }
    ],
    "afterFileEdit": [
      {
        "command": "uv run python .cursor/hooks/ruff_after_edit.py",
        "matcher": "Write",
        "timeout": 120
      },
      {
        "command": "uv run python .cursor/hooks/format_check.py",
        "matcher": "Write",
        "timeout": 30
      },
      {
        "command": "uv run python .cursor/hooks/typecheck.py",
        "matcher": "Write",
        "timeout": 120
      },
      {
        "command": "uv run python .cursor/hooks/pydantic_field_check.py",
        "matcher": "Write",
        "timeout": 10
      },
      {
        "command": "uv run python .cursor/hooks/feature_drift.py",
        "matcher": "Write",
        "timeout": 10
      }
    ],
    "stop": [
      {
        "command": "uv run python .cursor/hooks/pytest_on_agent_stop.py",
        "timeout": 600
      }
    ]
  }
}
