{
  "$schema": "https://unpkg.com/cursor-hooks@latest/schema/hooks.schema.json",
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": "uv run python .cursor/hooks/scope_check.py",
        "matcher": "Write",
        "timeout": 10
      },
      {
        "command": "uv run python .cursor/hooks/pre_task_check.py",
        "matcher": "Write",
        "timeout": 10
      },
      {
        "command": "uv run python .cursor/hooks/pr_checklist.py",
        "matcher": "Shell",
        "timeout": 10
      },
      {
        "command": "uv run python .cursor/hooks/common_ci_failures.py",
        "matcher": "Shell",
        "timeout": 10
      },
      {
        "command": "uv run python .cursor/hooks/shell_deploy_guard.py",
        "matcher": "Shell",
        "timeout": 10
      }
    ],
    "afterFileEdit": [
      {
        "command": "uv run python .cursor/hooks/make_format_lint_fix.py",
        "matcher": "Write|TabWrite",
        "timeout": 300
      },
      {
        "command": "uv run python .cursor/hooks/common_ci_failures.py",
        "matcher": "Write|TabWrite",
        "timeout": 180
      },
      {
        "command": "uv run python .cursor/hooks/typecheck.py",
        "matcher": "Write",
        "timeout": 120
      },
      {
        "command": "uv run python .cursor/hooks/pydantic_field_check.py",
        "matcher": "Write",
        "timeout": 10
      },
      {
        "command": "uv run python .cursor/hooks/feature_drift.py",
        "matcher": "Write",
        "timeout": 10
      },
      {
        "command": "uv run python .cursor/hooks/type_suppression_check.py",
        "matcher": "Write",
        "timeout": 15
      }
    ],
    "stop": [
      {
        "command": "uv run python .cursor/hooks/make_ci_on_stop.py",
        "timeout": 3600
      }
    ]
  }
}
