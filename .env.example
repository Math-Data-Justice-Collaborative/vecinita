# Vecinita environment template
# Copy this to `.env` and fill in your own values.
# Never commit real credentials.

# API/provider keys
GROQ_API_KEY=
OPEN_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
TAVILY_API_KEY=
HUGGINGFACE_ACCESS_TOKEN=
GUARDRAILS_AI_API_KEY=

# LangSmith
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=vecinita

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_PERSONAL_ACCESS_TOKEN=
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# Data DB routing
# Keep Supabase for auth/session flows, and use Postgres for vector data paths.
DB_DATA_MODE=postgres
POSTGRES_DATA_READS_ENABLED=true
SUPABASE_DATA_READS_ENABLED=true
VECTOR_SYNC_TARGET=postgres
VECTOR_SYNC_SUPABASE_FALLBACK_READS=false

# Render Postgres (internal network) example
# Use the internal hostname from Render for same-region services.
RENDER_POSTGRES_HOST=dpg-xxxxxxxxxxxxxxx-a
RENDER_POSTGRES_PORT=5432
RENDER_POSTGRES_DB=vecinita_postgres
RENDER_POSTGRES_USER=vecinita_postgres_user
RENDER_POSTGRES_PASSWORD=replace-me
# If password includes reserved URL chars, URL-encode it first.
RENDER_DATABASE_URL=postgresql://vecinita_postgres_user:replace-me@dpg-xxxxxxxxxxxxxxx-a:5432/vecinita_postgres?sslmode=require

# Embedding/model selection
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
USE_LOCAL_EMBEDDINGS=true
EMBEDDING_PROVIDER=fastembed
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://vecinita-modal-proxy-v1:10000/model
OLLAMA_MODEL=llama3.1:8b
AGENT_ENFORCE_PROXY=true
LOCK_MODEL_SELECTION=true
FORCE_LOCAL_MODAL_LLM=true
RENDER_REMOTE_INFERENCE_ONLY=true
RENDER_DISABLE_LOCAL_GUARDRAILS=true

# Proxy-first service wiring
# All backend model/embedding calls should route through modal-proxy.
MODAL_OLLAMA_ENDPOINT=http://vecinita-modal-proxy-v1:10000/model
MODAL_EMBEDDING_ENDPOINT=http://vecinita-modal-proxy-v1:10000/embedding
VECINITA_MODEL_API_URL=
VECINITA_EMBEDDING_API_URL=
EMBEDDING_SERVICE_URL=http://vecinita-modal-proxy-v1:10000/embedding
REINDEX_SERVICE_URL=http://vecinita-modal-proxy-v1:10000/jobs
REINDEX_TRIGGER_TOKEN=
REINDEX_CRON_SCHEDULE=0 2 * * 0
SCRAPER_REINDEX_CLEAN=false
SCRAPER_REINDEX_VERBOSE=false

# Modal credentials
MODAL_API_PROFILE=vecinita
# Preferred runtime credentials for proxy-authenticated Modal endpoints
# like vecinita-model and vecinita-embedding.
MODAL_API_PROXY_KEY=
MODAL_API_PROXY_SECRET=
# CLI/deploy credentials. These remain valid fallbacks when runtime proxy
# credentials are not configured separately.
MODAL_API_TOKEN_ID=
MODAL_API_TOKEN_SECRET=
# Legacy names still honored by local compose and service repos.
MODAL_AUTH_KEY=
MODAL_AUTH_SECRET=
PROXY_AUTH_TOKEN=
MODAL_PROXY_AUTH_TOKEN=

# Gateway/admin
GATEWAY_PORT=8004
DEV_ADMIN_ENABLED=true
DEV_ADMIN_BEARER_TOKEN=

# Search edge function
DB_SEARCH_EDGE_FUNCTION=search-similar-documents
DB_SEARCH_EDGE_TIMEOUT=12
DB_SEARCH_EDGE_URL=
DB_SEARCH_FORCE_SQL_FALLBACK=false
DB_SEARCH_TRY_TEXT_WRAPPER=false

# Optional deployment/integration tokens
CODECOV_TOKEN=
GCLOUD_API_KEY=
GCLOUD_PROJECT_NUMBER=
GCLOUD_PROJECT_ID=
RENDER_VECINITA_EMBEDDING_DEPLOY_HOOK=
RENDER_VECINITA_AGENT_DEPLOY_HOOK=
RENDER_VECINITA_FRONTEND_DEPLOY_HOOK=

# Runtime flags
TF_ENABLE_ONEDNN_OPTS=0
