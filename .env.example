# LOCAL DEVELOPMENT ENVIRONMENT (example)
# Copy this file to .env and fill in real values.

# ---------------------------------
# Local Supabase Configuration
# ---------------------------------
SUPABASE_URL=http://localhost:3001
SUPABASE_KEY=<your-local-supabase-anon-key>

# ---------------------------------
# Local Chroma Configuration
# ---------------------------------
CHROMA_HOST=localhost
CHROMA_PORT=8002
CHROMA_SSL=false
CHROMA_COLLECTION_CHUNKS=vecinita_chunks
CHROMA_COLLECTION_SOURCES=vecinita_sources
CHROMA_COLLECTION_QUEUE=vecinita_queue

# Local database connection (PostgreSQL in Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# ---------------------------------
# API Keys
# ---------------------------------
HUGGINGFACE_ACCESS_TOKEN=<your-huggingface-token>

# ---------------------------------
# LangSmith Configuration
# ---------------------------------
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=<your-langsmith-api-key>
LANGSMITH_PROJECT=<your-langsmith-project-name>

# ---------------------------------
# Embedding Model Config
# ---------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
USE_LOCAL_EMBEDDINGS=true

# ---------------------------------
# Modal Deployment Configuration
# ---------------------------------
# Modal credentials for server-side execution
# Generate tokens at: https://modal.com/settings/tokens
MODAL_API_PROFILE=vecinita
MODAL_API_TOKEN_ID=<your-modal-token-id>
MODAL_API_TOKEN_SECRET=<your-modal-token-secret>
# Proxy-native aliases used by vecinita-modal-proxy and now supported by backend services.
MODAL_TOKEN_ID=<your-modal-token-id>
MODAL_TOKEN_SECRET=<your-modal-token-secret>
MODAL_API_KEY=<optional-modal-api-key>
MODAL_API_PROXY_SECRET=<optional-modal-proxy-secret>

# Modal app configuration
MODAL_SECRET_NAME=vecinita-secrets
MODAL_EMBEDDING_APP_NAME=vecinita-embedding
MODAL_SCRAPER_APP_NAME=vecinita-scraper

# Modal endpoints (set when using Modal-hosted services)
# Format: https://workspace--appname.modal.run
MODAL_EMBEDDING_ENDPOINT=<your-modal-embedding-endpoint>
MODAL_OLLAMA_ENDPOINT=<your-modal-ollama-endpoint>

# Embedding and reindex service wiring
# LOCAL DEVELOPMENT: http://localhost:8001 (local FastAPI service)
# PRODUCTION: Use MODAL_EMBEDDING_ENDPOINT above
EMBEDDING_SERVICE_URL=http://localhost:8001
EMBEDDING_SERVICE_AUTH_TOKEN=
EMBEDDING_SERVICE_TIMEOUT=30

# Reindex service configuration
# LOCAL DEVELOPMENT: http://localhost:8001 (same embedding service with /reindex endpoint)
# PRODUCTION: Modal scraper service URL
REINDEX_SERVICE_URL=
REINDEX_TRIGGER_TOKEN=<secure-token-for-reindex-endpoint>
REINDEX_CRON_SCHEDULE=0 2 * * 0
SCRAPER_REINDEX_CLEAN=false
SCRAPER_REINDEX_VERBOSE=false

# ---------------------------------
# Local LLM Config (Ollama)
# ---------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ---------------------------------
# TensorFlow Configuration
# ---------------------------------
TF_ENABLE_ONEDNN_OPTS=0

# ---------------------------------
# Development Settings
# ---------------------------------
DEBUG=true
LOG_LEVEL=DEBUG
