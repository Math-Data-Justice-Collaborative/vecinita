    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.13.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.18.0",
    "vite": "^8.0.16",
