{
  "components": {
    "schemas": {
      "ChunkingConfig": {
        "description": "Semantic chunking parameters applied after Docling extraction.",
        "properties": {
          "max_size_tokens": {
            "default": 1024,
            "description": "Hard maximum chunk size in tokenizer tokens.",
            "examples": [
              1024
            ],
            "minimum": 200.0,
            "title": "Max Size Tokens",
            "type": "integer"
          },
          "min_size_tokens": {
            "default": 256,
            "description": "Soft minimum chunk size in tokenizer tokens.",
            "examples": [
              256
            ],
            "minimum": 100.0,
            "title": "Min Size Tokens",
            "type": "integer"
          },
          "overlap_ratio": {
            "default": 0.2,
            "description": "Fraction of overlap between adjacent chunks.",
            "examples": [
              0.2
            ],
            "maximum": 0.5,
            "minimum": 0.0,
            "title": "Overlap Ratio",
            "type": "number"
          },
          "split_by_sentence": {
            "default": true,
            "description": "Prefer sentence boundaries when splitting.",
            "examples": [
              true
            ],
            "title": "Split By Sentence",
            "type": "boolean"
          }
        },
        "title": "ChunkingConfig",
        "type": "object"
      },
      "CrawlConfig": {
        "description": "Tuning knobs for the Crawl4AI crawl stage.",
        "properties": {
          "delay_before_return_html_seconds": {
            "default": 1.5,
            "description": "Extra settle time before HTML snapshot when wait_for_content is enabled.",
            "examples": [
              1.5
            ],
            "maximum": 30.0,
            "minimum": 0.0,
            "title": "Delay Before Return Html Seconds",
            "type": "number"
          },
          "headless": {
            "default": true,
            "description": "Run the browser headless.",
            "examples": [
              true
            ],
            "title": "Headless",
            "type": "boolean"
          },
          "include_images": {
            "default": false,
            "description": "Whether to download image assets (higher bandwidth).",
            "examples": [
              false
            ],
            "title": "Include Images",
            "type": "boolean"
          },
          "include_links": {
            "default": true,
            "description": "Whether discovered links are enqueued for deeper crawling.",
            "examples": [
              true
            ],
            "title": "Include Links",
            "type": "boolean"
          },
          "max_depth": {
            "default": 3,
            "description": "Maximum link depth to follow from the seed URL.",
            "examples": [
              3
            ],
            "maximum": 10.0,
            "minimum": 1.0,
            "title": "Max Depth",
            "type": "integer"
          },
          "max_direct_fetch_bytes": {
            "default": 15000000,
            "description": "Maximum bytes to download for direct PDF/text fetches (non-browser path).",
            "examples": [
              15000000
            ],
            "maximum": 50000000.0,
            "minimum": 64000.0,
            "title": "Max Direct Fetch Bytes",
            "type": "integer"
          },
          "timeout_seconds": {
            "default": 60,
            "description": "Per-page navigation timeout in seconds.",
            "examples": [
              60
            ],
            "maximum": 600.0,
            "minimum": 10.0,
            "title": "Timeout Seconds",
            "type": "integer"
          },
          "wait_for_content": {
            "default": true,
            "description": "Wait for dynamic content before extraction.",
            "examples": [
              true
            ],
            "title": "Wait For Content",
            "type": "boolean"
          }
        },
        "title": "CrawlConfig",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "JobStatus": {
        "description": "Job status progression throughout the pipeline.",
        "enum": [
          "pending",
          "validating",
          "crawling",
          "extracting",
          "processing",
          "chunking",
          "embedding",
          "storing",
          "completed",
          "failed",
          "cancelled"
        ],
        "title": "JobStatus",
        "type": "string"
      },
      "JobStatusResponse": {
        "description": "Current status of a scraping job.",
        "examples": [
          {
            "chunk_count": 0,
            "crawl_url_count": 3,
            "created_at": "2024-02-09T10:00:00Z",
            "current_step": "crawl",
            "embedding_count": 0,
            "job_id": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
            "progress_pct": 25,
            "status": "crawling",
            "updated_at": "2024-02-09T10:05:00Z"
          },
          {
            "chunk_count": 40,
            "crawl_url_count": 12,
            "created_at": "2024-02-09T10:00:00Z",
            "current_step": "done",
            "embedding_count": 40,
            "job_id": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
            "progress_pct": 100,
            "status": "completed",
            "updated_at": "2024-02-09T10:30:00Z"
          },
          {
            "chunk_count": 0,
            "crawl_url_count": 1,
            "created_at": "2024-02-09T10:00:00Z",
            "current_step": "extract",
            "embedding_count": 0,
            "error_message": "Extraction timeout",
            "job_id": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
            "progress_pct": 10,
            "status": "failed",
            "updated_at": "2024-02-09T10:08:00Z"
          },
          {
            "chunk_count": 0,
            "crawl_url_count": 0,
            "created_at": "2024-02-09T10:00:00Z",
            "current_step": "queued",
            "embedding_count": 0,
            "job_id": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
            "progress_pct": 0,
            "status": "pending",
            "updated_at": "2024-02-09T10:00:00Z"
          },
          {
            "chunk_count": 10,
            "crawl_url_count": 5,
            "created_at": "2024-02-09T10:00:00Z",
            "current_step": "chunking",
            "embedding_count": 0,
            "job_id": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
            "progress_pct": 50,
            "status": "cancelled",
            "updated_at": "2024-02-09T10:15:00Z"
          }
        ],
        "properties": {
          "chunk_count": {
            "default": 0,
            "title": "Chunk Count",
            "type": "integer"
          },
          "crawl_url_count": {
            "default": 0,
            "title": "Crawl Url Count",
            "type": "integer"
          },
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "current_step": {
            "title": "Current Step",
            "type": "string"
          },
          "embedding_count": {
            "default": 0,
            "title": "Embedding Count",
            "type": "integer"
          },
          "error_message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Message"
          },
          "job_id": {
            "title": "Job Id",
            "type": "string"
          },
          "progress_pct": {
            "maximum": 100.0,
            "minimum": 0.0,
            "title": "Progress Pct",
            "type": "integer"
          },
          "status": {
            "$ref": "#/components/schemas/JobStatus"
          },
          "updated_at": {
            "format": "date-time",
            "title": "Updated At",
            "type": "string"
          }
        },
        "required": [
          "job_id",
          "status",
          "progress_pct",
          "current_step",
          "updated_at",
          "created_at"
        ],
        "title": "JobStatusResponse",
        "type": "object"
      },
      "ScrapeJobCancelResponse": {
