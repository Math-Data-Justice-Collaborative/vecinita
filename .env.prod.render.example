# Shared Render production environment contract template
# Values shown are placeholders. Real secrets stay in Render dashboard.

ALLOWED_ORIGINS=https://vecinita-frontend.onrender.com
CORS_ORIGINS=https://vecinita-data-management-frontend-v1.onrender.com
DATABASE_URL=postgresql://user:password@host:5432/db?sslmode=require
# Modal secret vecinita-scraper-env only: same DB, external hostname from Render Postgres
# "Connect" → External URL (https://render.com/docs/postgresql-creating-connecting#external-connections).
# Internal dpg-*-a hosts do not resolve from Modal workers.
# MODAL_DATABASE_URL=postgresql://user:password@oregon-postgres.render.com:5432/db?sslmode=require
DB_DATA_MODE=postgres
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
EMBEDDING_SERVICE_AUTH_TOKEN=replace-me
GROQ_API_KEY=
MODAL_TOKEN_ID=replace-me
MODAL_TOKEN_SECRET=replace-me
MODAL_FUNCTION_INVOCATION=auto
MODAL_WORKSPACE=vecinita
OLLAMA_MODEL=gemma3
OPENAI_API_KEY=
RENDER_REMOTE_INFERENCE_ONLY=true
# Comma-separated Bearer secrets for the scraper HTTP API (Render + callers). Replace in prod.
SCRAPER_API_KEYS=render-contract-example-key-alpha,render-contract-example-key-bravo
# Modal embedding HTTPS base (no path). Prefer web_app deploy (*-embedding-web-app.modal.run).
# Legacy *-embeddingservicecontainer-api.modal.run is rewritten at runtime in the gateway when
# still present in env; operators should update to the canonical host below.
VECINITA_EMBEDDING_API_URL=https://vecinita--vecinita-embedding-web-app.modal.run
VECINITA_MODEL_API_URL=https://vecinita--vecinita-model-api.modal.run
VECINITA_SCRAPER_API_URL=https://vecinita--vecinita-scraper-api-fastapi.modal.run/jobs
# Optional HTTP-mode fallback only. Leave empty when using Modal function invocation.
REINDEX_SERVICE_URL=
# Optional; when set, forwarded as x-reindex-token to the scraper reindex endpoint.
REINDEX_TRIGGER_TOKEN=
# vecinita-gateway: omit on Render — render.yaml injects AGENT_SERVICE_URL via fromService (host:port).
# For local CLI/tests, set in .env e.g. AGENT_SERVICE_URL=http://localhost:8000 (see .env.local.example).
VITE_BACKEND_URL=https://vecinita-gateway.onrender.com/api/v1
VITE_DEFAULT_SCRAPER_USER_ID=frontend-user
VITE_GATEWAY_URL=https://vecinita-gateway.onrender.com/api/v1
VITE_VECINITA_SCRAPER_API_URL=https://vecinita-data-management-api-v1.onrender.com
