# Vecinita Backend Environment Variables Template
# Copy this file to .env and fill in your actual values

# ---------------------------------
# API Keys
# ---------------------------------
TAVILY_API_KEY=your-tavily-api-key-here

# ---------------------------------
# Agent Provider Configuration
# Only the local Ollama runtime is supported
# ---------------------------------
DEFAULT_PROVIDER=ollama

# ---------------------------------
# Local LLM Config (Ollama) - OPTIONAL
# Only use if running Ollama locally. Otherwise leave commented out.
# Install Ollama from https://ollama.ai
# WARNING: If OLLAMA_BASE_URL is set but Ollama is not running, connection will be refused
# Ensure Ollama is running before setting these values
# ---------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ---------------------------------
# CORS Configuration (Gateway Service)
# Comma-separated list of allowed frontend origins
# ---------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:4173,https://your-frontend-domain.com

# ---------------------------------
# Service URLs (for Gateway)
# ---------------------------------
AGENT_SERVICE_URL=http://localhost:8000
EMBEDDING_SERVICE_URL=http://localhost:8001
REINDEX_SERVICE_URL=
GATEWAY_PORT=8004

# Embedding service auth
# Required for Docker Compose startup and any environment where embedding-service enforces token auth.
# You may instead set MODAL_API_PROXY_SECRET and let compose mirror it into EMBEDDING_SERVICE_AUTH_TOKEN.
EMBEDDING_SERVICE_AUTH_TOKEN=

# Scraper reindex trigger auth (gateway -> Modal scraper endpoint)
REINDEX_TRIGGER_TOKEN=

# Weekly Modal schedule for scraper reindex job (Sunday 02:00 UTC default)
REINDEX_CRON_SCHEDULE=0 2 * * 0
SCRAPER_REINDEX_CLEAN=false
SCRAPER_REINDEX_VERBOSE=false

# Local dev admin login fallback (only for local development)
DEV_ADMIN_ENABLED=true
DEV_ADMIN_BEARER_TOKEN=vecinita-dev-admin-token-2026

# ---------------------------------
# Gateway Configuration
# ---------------------------------
MAX_URLS_PER_REQUEST=100
JOB_RETENTION_HOURS=24
AGENT_TIMEOUT=30
AGENT_STREAM_TIMEOUT=120

# ---------------------------------
# Codecov Token
# For uploading test coverage reports
# ---------------------------------
CODECOV_TOKEN=your-codecov-token-here

# ---------------------------------
# TensorFlow Configuration
# ---------------------------------
TF_ENABLE_ONEDNN_OPTS=0

# ---------------------------------
# Additional Services
# ---------------------------------

# ---------------------------------
# LangSmith Configuration
# For tracing and monitoring agent runs
# ---------------------------------
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=your-project-name

# ---------------------------------
# Supabase API (for main.py)
# This MUST start with https://
# ---------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-here

# ---------------------------------
# ChromaDB (Vector/document CRUD storage)
# ---------------------------------
CHROMA_HOST=localhost
CHROMA_PORT=8002
CHROMA_SSL=false
CHROMA_COLLECTION_CHUNKS=vecinita_chunks
CHROMA_COLLECTION_SOURCES=vecinita_sources
CHROMA_COLLECTION_QUEUE=vecinita_queue

# ---------------------------------
# Direct Database Connection (for vector_loader.py, data_scrape_load.sh)
# This MUST start with postgresql://
# ---------------------------------
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# ---------------------------------
# PostgreSQL Database Credentials
# Used by scraper CLI and PowerShell scripts
# ---------------------------------
DB_HOST=db.your-project.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-db-password

# ---------------------------------
# Embedding Model Config
# ---------------------------------
EMBEDDING_MODEL=text-embedding-3-small
USE_LOCAL_EMBEDDINGS=true
