FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    HF_HOME=/tmp/huggingface_cache \
    PYTHONPATH=/app/modal-apps/embedding-modal/src

WORKDIR /app

COPY modal-apps/embedding-modal/pyproject.toml /app/modal-apps/embedding-modal/pyproject.toml
COPY modal-apps/embedding-modal/README.md /app/modal-apps/embedding-modal/README.md
COPY modal-apps/embedding-modal/src /app/modal-apps/embedding-modal/src
COPY docker/microservices/embedding_asgi.py /app/embedding_asgi.py

RUN pip install --no-cache-dir --upgrade pip setuptools wheel \
    && pip install --no-cache-dir -e /app/modal-apps/embedding-modal

EXPOSE 8011

CMD ["uvicorn", "embedding_asgi:app", "--host", "0.0.0.0", "--port", "8011"]
