# Supabase CLI / config-push — environment (EXAMPLE / placeholders only)
#
# Used when running the Supabase CLI locally or in CI to manage the canonical
# project (cfuvghdsuwactfeamtym): `supabase link`, `supabase db push`,
# `supabase config push` (auth settings + email templates, ADR-027/ADR-030).
#
# Copy to a local gitignored file and source it, or rely on repo-root prod.env:
#
#   set -a && source prod.env && set +a
#   export SUPABASE_DB_PASSWORD="$SUPABASE_DATABASE_PASSWORD"   # name mapping, see below
#   supabase link --project-ref "$SUPABASE_PROJECT_ID" --password "$SUPABASE_DB_PASSWORD"
#   supabase config push                                       # pushes config.toml + templates
#
# Helper (preferred): bash scripts/supabase/ci_sync.sh sync-production
# Matrix: docs/staging-secrets-matrix.md §Supabase project
# NEVER commit real secrets to git.

# ---------------------------------------------------------------------------
# CLI authentication + project link
# ---------------------------------------------------------------------------
SUPABASE_ACCESS_TOKEN=sbp_<personal-access-token>   # account token (cloud commands)
SUPABASE_PROJECT_ID=cfuvghdsuwactfeamtym            # canonical project ref
SUPABASE_URL=https://cfuvghdsuwactfeamtym.supabase.co

# NOTE: prod.env stores the DB password as SUPABASE_DATABASE_PASSWORD; the CLI and
# supabase.yml expect SUPABASE_DB_PASSWORD. Map it before running the CLI:
#   export SUPABASE_DB_PASSWORD="$SUPABASE_DATABASE_PASSWORD"
SUPABASE_DB_PASSWORD=<supabase-db-password>

# ---------------------------------------------------------------------------
# Admin API (server-side scripts only — e.g. seed_first_admin.py)
# Not required for config push; never ship to the browser.
# ---------------------------------------------------------------------------
SUPABASE_SECRET_KEY=sb_secret_<secret-key>
SUPABASE_PUBLISHABLE_KEY=sb_publishable_<publishable-key>

# ---------------------------------------------------------------------------
# EV-006 (F35) — Resend SMTP credential resolved by config.toml at `config push`
# [auth.email.smtp] pass = "env(SUPABASE_SMTP_PASS)" → Resend API key (re_...)
# In prod.env use RESEND_API_KEY or SUPABASE_SMTP_PASS; sync_github_secrets.sh maps
# RESEND_API_KEY → SUPABASE_SMTP_PASS when pushing to GitHub Actions.
# Operator prerequisite: verified Resend sending domain (SPF/DKIM) + sender address.
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_<resend-api-key>
# SUPABASE_SMTP_PASS=re_<resend-api-key>   # alternative name (same value)
