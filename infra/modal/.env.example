# Modal — vecinita workspace secrets (EXAMPLE / placeholders only)
#
# Modal apps read env from the secret `vecinita-data-management` (and deploy-time URLs).
# Create or update the secret in the Modal dashboard or CLI — never commit real values.
#
# Dashboard: https://modal.com/secrets/vecinita/main/create?secret_name=vecinita-data-management
# CLI (from repo root, after `modal profile activate vecinita`):
#
#   set -a && source prod.env && set +a
#   modal secret create vecinita-data-management \
#     VECINITA_MODAL_EMBED_URL="$VECINITA_MODAL_EMBED_URL" \
#     VECINITA_INTERNAL_WRITE_URL="$VECINITA_INTERNAL_WRITE_URL" \
#     VECINITA_INTERNAL_API_KEY="$VECINITA_INTERNAL_API_KEY" \
#     VECINITA_MODAL_PROXY_KEY="$VECINITA_MODAL_PROXY_KEY" \
#     VECINITA_CORS_ORIGINS="$VECINITA_CORS_ORIGINS" \
#     VECINITA_MODAL_LLM_URL="$VECINITA_MODAL_LLM_URL" \
#     SUPABASE_URL="$SUPABASE_URL" \
#     VECINITA_AUTH_REQUIRED=true
#
# Or use the helper scripts (recommended):
#   bash scripts/deploy/sync_modal_secret.sh           # dry run (lists keys)
#   bash scripts/deploy/sync_modal_secret.sh --apply   # write the secret
#   bash scripts/deploy/sync_env.sh --modal --apply    # same, via the orchestrator
#
# Update existing secret (merge keys; does not remove unlisted keys):
#   modal secret create --force vecinita-data-management KEY=value ...
#
# Verify before deploy: bash scripts/deploy/verify_secrets.sh
# Deploy: bash scripts/deploy/modal.sh
#
# Matrix: docs/staging-secrets-matrix.md §Modal
# NEVER commit real secrets to git. DATABASE_URL is forbidden on Modal (ADR-007).

# ---------------------------------------------------------------------------
# vecinita-data-management  (Modal secret: vecinita-data-management)
# Used by: infra/modal/data_management_app.py — ASGI /jobs + ingest workers
# ---------------------------------------------------------------------------

# Upstream Modal apps (deploy embedding + llm first; copy URLs from deploy output)
VECINITA_MODAL_EMBED_URL=https://vecinita--vecinita-embedding-embedding-api.modal.run
VECINITA_MODAL_LLM_URL=https://vecinita--vecinita-llm-fastapi-app.modal.run

# DigitalOcean internal write API (sole DATABASE_URL holder — ADR-007)
VECINITA_INTERNAL_WRITE_URL=https://vecinita-internal-write-api-<id>.ondigitalocean.app
VECINITA_INTERNAL_API_KEY=<same-as-do-VECINITA_INTERNAL_API_KEY>

# Edge proxy + browser CORS (must match admin frontend origin)
VECINITA_MODAL_PROXY_KEY=<same-as-VITE_VECINITA_MODAL_PROXY_KEY>
VECINITA_CORS_ORIGINS=https://vecinita-admin-frontend-<id>.ondigitalocean.app,https://vecinita-chat-rag-frontend-<id>.ondigitalocean.app

# EV-005 F34 — Supabase JWT verification on /jobs* (ES256/JWKS; ADR-028)
SUPABASE_URL=https://<project-ref>.supabase.co
VECINITA_AUTH_REQUIRED=true
# SUPABASE_JWT_AUD=authenticated

# EV-006 F35 — Supabase Admin API for /admin/users* (ADR-030 / TP-S005-01).
# Server-side only; this is the ONLY running service that holds SUPABASE_SECRET_KEY.
# Never in DigitalOcean apps and never in any VITE_* browser build.
SUPABASE_SECRET_KEY=sb_secret_<your-secret-key>

# Optional ingest / tagging tuning
# VECINITA_LLM_TAG_MAX_TOKENS=128
# VECINITA_TAG_SEED_PATH=data/fixtures/tags/seed_tags.json

# ---------------------------------------------------------------------------
# Operator-only (NOT in Modal secret — prod.env / shell for bootstrap scripts)
# ---------------------------------------------------------------------------
# SUPABASE_ADMIN_EMAIL=admin@example.com
# SUPABASE_ADMIN_PASSWORD=<strong-password>
# Used by: uv run python scripts/seed_first_admin.py
#
# EV-006 F35 — Resend REST test-send (ADR-031 / TP-S005-22). Same key as SUPABASE_SMTP_PASS.
# RESEND_API_KEY=re_...
# RESEND_SENDER_EMAIL=noreply@<verified-resend-domain>  # must match config.toml admin_email

# ---------------------------------------------------------------------------
# vecinita-embedding / vecinita-llm — no extra secrets (weights on Modal volumes)
# ---------------------------------------------------------------------------
# Stage weights once: ./scripts/stage_modal_weights.sh
