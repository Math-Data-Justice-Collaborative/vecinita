# GitHub Actions — repository secrets (EXAMPLE / placeholders only)
#
# Best practices:
#   - Store ALL values as GitHub Actions encrypted secrets (Settings → Secrets → Actions).
#   - Never commit real tokens; use prod.env (gitignored) + sync_github_secrets.sh.
#   - Supabase: SUPABASE_ACCESS_TOKEN, SUPABASE_DB_PASSWORD per Supabase CI guide.
#   - Modal CD: MODAL_TOKEN_ID + MODAL_TOKEN_SECRET per modal.com/docs/guide/continuous-deployment
#   - DigitalOcean: DIGITALOCEAN_TOKEN with Apps read/write scope.
#   - Resend: RESEND_API_KEY synced as SUPABASE_SMTP_PASS for config push (see infra/resend/)
#
# Workflows that consume these secrets:
#   .github/workflows/ci.yml                  — no secrets
#   .github/workflows/supabase.yml            — Supabase sync (config + db push)
#   .github/workflows/deploy-preflight.yml    — Modal token smoke
#   .github/workflows/deploy-modal.yml        — Supabase sync + Modal secret sync + deploy
#   .github/workflows/deploy-digitalocean.yml — Alembic + DO secret sync + deploy
#
# Push from prod.env:
#
#   set -a && source prod.env && set +a
#   bash scripts/deploy/sync_github_secrets.sh            # dry run
#   bash scripts/deploy/sync_github_secrets.sh --apply    # gh secret set
#
# Canonical repo: Math-Data-Justice-Collaborative/vecinita
# Master template: prod.env.example
# Matrix: docs/staging-secrets-matrix.md §GitHub Actions
# NEVER commit real secrets to git.

# ---------------------------------------------------------------------------
# Deploy credentials
# ---------------------------------------------------------------------------
DIGITALOCEAN_TOKEN=dop_v1_<your-do-api-token>
MODAL_TOKEN_ID=ak-<your-modal-token-id>
MODAL_TOKEN_SECRET=as-<your-modal-token-secret>

# ---------------------------------------------------------------------------
# Postgres + cross-service auth (CI Alembic + DO/Modal env sync on deploy)
# ci_materialize_env.sh derives VITE_* and VECINITA_CORS_ORIGINS when omitted.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://doadmin:<password>@<host>:25060/defaultdb?sslmode=require
VECINITA_INTERNAL_API_KEY=<random-bearer-token-for-modal-and-legacy-clients>
VECINITA_CORS_ORIGINS=https://vecinita-admin-frontend-<id>.ondigitalocean.app,https://vecinita-chat-rag-frontend-<id>.ondigitalocean.app
VECINITA_MODAL_EMBED_URL=https://vecinita--vecinita-embedding-embedding-api.modal.run
VECINITA_MODAL_LLM_URL=https://vecinita--vecinita-llm-fastapi-app.modal.run
VECINITA_MODAL_DATA_MGMT_URL=https://vecinita--vecinita-data-management-fastapi-app.modal.run
VECINITA_MODAL_PROXY_KEY=<same-as-modal-secret-and-vite-modal-proxy-key>
VECINITA_INTERNAL_WRITE_URL=https://vecinita-internal-write-api-<id>.ondigitalocean.app
VECINITA_CHAT_RAG_URL=https://vecinita-chat-rag-backend-<id>.ondigitalocean.app
VECINITA_CHAT_FRONTEND_URL=https://vecinita-chat-rag-frontend-<id>.ondigitalocean.app
VECINITA_ADMIN_FRONTEND_URL=https://vecinita-admin-frontend-<id>.ondigitalocean.app
VECINITA_STATS_ENABLED=true

# ---------------------------------------------------------------------------
# DigitalOcean static sites (BUILD_TIME — rebuilt on each admin/chat frontend deploy)
# ---------------------------------------------------------------------------
VITE_VECINITA_ADMIN_API_URL=https://vecinita--vecinita-data-management-fastapi-app.modal.run
VITE_VECINITA_MODAL_PROXY_KEY=<same-as-VECINITA_MODAL_PROXY_KEY>
VITE_VECINITA_CORPUS_API_URL=https://vecinita-internal-write-api-<id>.ondigitalocean.app
VITE_VECINITA_CORPUS_API_KEY=<same-as-VECINITA_INTERNAL_API_KEY>
VITE_VECINITA_CHAT_API_URL=https://vecinita-chat-rag-backend-<id>.ondigitalocean.app
VITE_SUPABASE_URL=https://cfuvghdsuwactfeamtym.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<publishable-key>

# ---------------------------------------------------------------------------
# Supabase — CLI + config push (supabase.yml, deploy-modal.yml supabase-sync job)
# https://supabase.com/docs/guides/deployment/managing-environments
# ---------------------------------------------------------------------------
SUPABASE_ACCESS_TOKEN=sbp_<personal-access-token>
SUPABASE_DB_PASSWORD=<supabase-db-password>
SUPABASE_PROJECT_ID=cfuvghdsuwactfeamtym
SUPABASE_URL=https://cfuvghdsuwactfeamtym.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_<publishable-key>
SUPABASE_SECRET_KEY=sb_secret_<secret-key>
SUPABASE_ADMIN_EMAIL=admin@vecinita.admin
SUPABASE_ADMIN_PASSWORD=<strong-password>

# ---------------------------------------------------------------------------
# Resend — see infra/resend/.env.example for the 3-way sync (GitHub + Supabase + Modal)
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_<resend-api-key>
RESEND_SENDER_EMAIL=noreply@josephcmcg.com
SUPABASE_SMTP_PASS=re_<resend-api-key>
