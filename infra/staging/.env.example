# Staging connectivity env (H4–H5) — copy to prod.env or export before operator smokes.
# See docs/staging-runbook.md and scripts/deploy/verify_connectivity.sh

# API liveness + RAG smoke (H1, H3, H4)
# VECINITA_STAGING_CHAT_URL=https://<chat-rag-backend>.ondigitalocean.app

# Internal write API (H1 optional, H4, H5)
# VECINITA_STAGING_WRITE_URL=https://<internal-write-api>.ondigitalocean.app

# Static frontends — required for live CORS preflight + bundle wiring (H4, H5)
# VECINITA_STAGING_CHAT_FRONTEND_URL=https://<chat-ui>.ondigitalocean.app
# VECINITA_STAGING_ADMIN_FRONTEND_URL=https://<admin-ui>.ondigitalocean.app

# Modal data-management jobs API (H4 admin CORS)
# VECINITA_STAGING_ADMIN_API_URL=https://vecinita--vecinita-data-management-fastapi-app.modal.run

# Database readiness (H2) — falls back to DATABASE_URL when unset
# VECINITA_STAGING_DATABASE_URL=postgresql://...

# EV-002 admin integration smokes (optional)
# VECINITA_STAGING_INTERNAL_API_KEY=

# Run locally (skips live tiers when all URLs unset — exit 0):
#   bash scripts/deploy/verify_connectivity.sh
# Or:
#   make verify-connectivity
