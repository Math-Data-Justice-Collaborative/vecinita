# GitHub Actions — repository secrets (EXAMPLE / placeholders only)
#
# These are the secrets consumed by the GitHub Actions workflows:
#   - .github/workflows/ci.yml              (no secrets; lint/type/test)
#   - .github/workflows/supabase.yml        (SUPABASE_ACCESS_TOKEN, SUPABASE_DB_PASSWORD,
#                                            SUPABASE_PROJECT_ID, + EV-006 SUPABASE_SMTP_PASS
#                                            so `config push` can resolve env(SUPABASE_SMTP_PASS))
#   - .github/workflows/deploy-modal.yml    (MODAL_TOKEN_ID, MODAL_TOKEN_SECRET)
#   - .github/workflows/deploy-digitalocean.yml (DIGITALOCEAN_TOKEN)
#   - .github/workflows/deploy-preflight.yml (MODAL_TOKEN_* when present)
#
# Master secret store is repo-root prod.env (gitignored). Push to GitHub with the CLI:
#
#   set -a && source prod.env && set +a
#   bash scripts/deploy/sync_github_secrets.sh            # dry run (lists keys + state)
#   bash scripts/deploy/sync_github_secrets.sh --apply    # gh secret set for the canonical repo
#
# Canonical repo: Math-Data-Justice-Collaborative/vecinita  (origin)
# Matrix: docs/staging-secrets-matrix.md §GitHub Actions
# NEVER commit real secrets to git.

# ---------------------------------------------------------------------------
# Deploy credentials (used by deploy-* workflows)
# ---------------------------------------------------------------------------
DIGITALOCEAN_TOKEN=dop_v1_<your-do-api-token>
MODAL_TOKEN_ID=ak-<your-modal-token-id>
MODAL_TOKEN_SECRET=as-<your-modal-token-secret>

# ---------------------------------------------------------------------------
# Supabase — env sync workflow (supabase.yml: validate / preview-branch / sync-production)
# ---------------------------------------------------------------------------
SUPABASE_ACCESS_TOKEN=sbp_<personal-access-token>   # https://supabase.com/dashboard/account/tokens
SUPABASE_DB_PASSWORD=<supabase-db-password>          # prod.env stores this as SUPABASE_DATABASE_PASSWORD
SUPABASE_PROJECT_ID=cfuvghdsuwactfeamtym
SUPABASE_URL=https://cfuvghdsuwactfeamtym.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_<publishable-key>
SUPABASE_SECRET_KEY=sb_secret_<secret-key>

# First-admin bootstrap (used by scripts/seed_first_admin.py when run in CI)
SUPABASE_ADMIN_EMAIL=admin@vecinita.admin
SUPABASE_ADMIN_PASSWORD=<strong-password>

# ---------------------------------------------------------------------------
# EV-006 (F35) — Resend SMTP for Supabase invitation / auth emails
# Referenced by supabase/config.toml: [auth.email.smtp] pass = "env(SUPABASE_SMTP_PASS)"
# `supabase config push` (sync-production job) resolves this from the workflow env,
# so it MUST be a GitHub Actions secret. Value = Resend API key (re_...).
# In prod.env you may use either name; sync_github_secrets.sh maps RESEND_API_KEY →
# SUPABASE_SMTP_PASS when pushing to GitHub.
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_<resend-api-key>
# SUPABASE_SMTP_PASS=re_<resend-api-key>   # alternative name (same value)
