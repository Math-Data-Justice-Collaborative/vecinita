# Backend-only overrides (optional).
# Copy the repository root `.env.example` to `../.env` (or `.env.local`) for the full catalog.
# Canonical environment catalog: repo root .env.example
#
# Typical local stack: set gateway/agent URLs here only if they differ from root defaults.

DEFAULT_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3
GATEWAY_PORT=8004
AGENT_SERVICE_URL=http://localhost:8000
EMBEDDING_SERVICE_URL=http://localhost:8001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=
