# GCP VM deploy template — copy to backend/.env on the target host.
# Canonical environment catalog: repo root .env.example

PORT=8000
GATEWAY_PORT=8004
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma3
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=gemma3
EMBEDDING_SERVICE_URL=https://YOUR_EMBED_SERVICE.run.app
EMBEDDING_SERVICE_AUTH_TOKEN=
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_SSL=false
CHROMA_COLLECTION_CHUNKS=vecinita_chunks
CHROMA_COLLECTION_SOURCES=vecinita_sources
CHROMA_COLLECTION_QUEUE=vecinita_queue
DEV_ADMIN_ENABLED=false
DEV_ADMIN_BEARER_TOKEN=
SUPABASE_UPLOADS_BUCKET=documents
GUARDRAILS_ENABLED=true
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
