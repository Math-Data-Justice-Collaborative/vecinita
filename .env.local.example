# Canonical local development environment template
# Copy to .env.local (or .env) for local development.
# This file is the single local source template for chat + data-management flows.

# --- LLM / provider keys ---
GROQ_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
TAVILY_API_KEY=

# --- Modal runtime credentials (preferred) ---
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_FUNCTION_INVOCATION=auto
MODAL_WORKSPACE=vecinita

# --- Legacy/CLI Modal aliases (kept for compatibility) ---
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# --- Core service routing (local defaults) ---
VECINITA_MODEL_API_URL=http://localhost:11434
VECINITA_EMBEDDING_API_URL=http://localhost:8001
VECINITA_SCRAPER_API_URL=http://localhost:8005/jobs
AGENT_SERVICE_URL=http://localhost:8000
# Gateway → agent HTTP read timeouts (seconds). Align with slow cold starts / long answers.
AGENT_TIMEOUT=180
AGENT_STREAM_TIMEOUT=180
REINDEX_SERVICE_URL=http://localhost:8005/jobs

# --- Gateway/frontend routing ---
VITE_GATEWAY_URL=http://localhost:8004/api/v1
VITE_BACKEND_URL=http://localhost:8004/api/v1
VITE_GATEWAY_PROXY_TARGET=http://127.0.0.1:8004
VITE_AGENT_REQUEST_TIMEOUT_MS=90000
VITE_AGENT_STREAM_TIMEOUT_MS=120000
VITE_AGENT_STREAM_FIRST_EVENT_TIMEOUT_MS=15000

# --- Data-management frontend routing ---
VITE_VECINITA_SCRAPER_API_URL=http://localhost:8005
VITE_DEFAULT_SCRAPER_USER_ID=frontend-user

# --- Modal scraper / Postgres split (mirror .env for hosted; see RENDER_SHARED_ENV_CONTRACT.md) ---
# Gateway: when 1, gateway persists scraping_jobs and Modal submit is enqueue-only.
MODAL_SCRAPER_PERSIST_VIA_GATEWAY=1
# Modal workers only: same DB as DATABASE_URL but use Render Postgres *external* hostname
# (…region-postgres.render.com), never internal dpg-*-a from outside Render. Empty for pure local.
MODAL_DATABASE_URL=

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# --- Shared data mode / bootstrap ---
DB_DATA_MODE=postgres
VECTOR_SYNC_TARGET=postgres
POSTGRES_DATA_READS_ENABLED=true
SUPABASE_DATA_READS_ENABLED=true
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=

# --- Runtime flags ---
RENDER_REMOTE_INFERENCE_ONLY=true
EMBEDDING_SERVICE_AUTH_TOKEN=local-embedding-auth-token
OLLAMA_MODEL=gemma3
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:4173

# --- Optional admin/dev auth ---
DEV_ADMIN_ENABLED=true
DEV_ADMIN_BEARER_TOKEN=vecinita-dev-admin-token-2026
