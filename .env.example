# Vecinita — canonical environment template (repository root)
# Copy to `.env` or `.env.local` for local use only. Never commit real credentials.
# Subsidiary `*/.env.example` files are minimal overlays; the full catalog lives here.
# Migration / aliases: docs/environment-migration.md

### REQUIRED — default local
# FR-009: when the setup guide promises Supabase + Postgres together, set both paths.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_GATEWAY_URL=http://localhost:8004/api/v1
VITE_BACKEND_URL=http://localhost:8004/api/v1
# Discrete DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD are optional when DATABASE_URL
# is set; backend derives them when unset (see docs/environment-migration.md).

### OPTIONAL PROFILE: alternate-llm-providers
GROQ_API_KEY=
OPEN_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
TAVILY_API_KEY=
HUGGINGFACE_ACCESS_TOKEN=
GUARDRAILS_AI_API_KEY=

### OPTIONAL PROFILE: langsmith-tracing
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=vecinita

### OPTIONAL PROFILE: supabase-extended
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_PERSONAL_ACCESS_TOKEN=

### OPTIONAL PROFILE: data-db-routing
# Keep Supabase for auth/session flows, and use Postgres for vector data paths.
DB_DATA_MODE=postgres
POSTGRES_DATA_READS_ENABLED=true
SUPABASE_DATA_READS_ENABLED=true
VECTOR_SYNC_TARGET=postgres
VECTOR_SYNC_SUPABASE_FALLBACK_READS=false

### OPTIONAL PROFILE: render-postgres
# Use the internal hostname from Render for same-region services.
RENDER_POSTGRES_HOST=dpg-xxxxxxxxxxxxxxx-a
RENDER_POSTGRES_PORT=5432
RENDER_POSTGRES_DB=vecinita_postgres
RENDER_POSTGRES_USER=vecinita_postgres_user
RENDER_POSTGRES_PASSWORD=replace-me
# If password includes reserved URL chars, URL-encode it first.
RENDER_DATABASE_URL=postgresql://vecinita_postgres_user:replace-me@dpg-xxxxxxxxxxxxxxx-a:5432/vecinita_postgres?sslmode=require

### OPTIONAL PROFILE: embedding-and-local-models
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
USE_LOCAL_EMBEDDINGS=true
EMBEDDING_PROVIDER=fastembed
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=gemma3
OLLAMA_BASE_URL=http://vecinita-model-ms-render:8000
OLLAMA_MODEL=gemma3
AGENT_ENFORCE_ROUTE=true
LOCK_MODEL_SELECTION=true
FORCE_LOCAL_MODAL_LLM=true
RENDER_REMOTE_INFERENCE_ONLY=true
RENDER_DISABLE_LOCAL_GUARDRAILS=true

### OPTIONAL PROFILE: local-chat-and-gateway-tuning
# Common `.env.local` overrides (timeouts, Modal workspace, scraper DB URL for workers).
AGENT_SERVICE_URL=http://localhost:8000
AGENT_TIMEOUT=180
AGENT_STREAM_TIMEOUT=180
MODAL_WORKSPACE=vecinita
MODAL_FUNCTION_INVOCATION=auto
MODAL_SCRAPER_PERSIST_VIA_GATEWAY=1
MODAL_DATABASE_URL=
ALLOWED_ORIGINS=
VITE_GATEWAY_PROXY_TARGET=http://127.0.0.1:8004
VITE_AGENT_REQUEST_TIMEOUT_MS=90000
VITE_AGENT_STREAM_TIMEOUT_MS=120000
VITE_AGENT_STREAM_FIRST_EVENT_TIMEOUT_MS=15000
VITE_VECINITA_SCRAPER_API_URL=http://localhost:8005
VITE_DEFAULT_SCRAPER_USER_ID=frontend-user

### OPTIONAL PROFILE: service-wiring-and-scraper
# FR-004 / FR-005 (feature 015): use canonical keys; legacy names are copied at startup via
# config/env_aliases.example.yaml (DeprecationWarning). Do not set MODAL_OLLAMA_ENDPOINT,
# MODAL_EMBEDDING_ENDPOINT, VECINITA_MODEL_API_URL, VECINITA_EMBEDDING_API_URL, or EMBEDDING_SERVICE_URL.
OLLAMA_BASE_URL=http://vecinita-model-ms-render:8000
EMBEDDING_UPSTREAM_URL=http://vecinita-embedding-ms-render:8011
VECINITA_SCRAPER_API_URL=
# Optional Render cross-service URLs (OpenAPI codegen / live tests); see docs/deployment/RENDER_SHARED_ENV_CONTRACT.md
# RENDER_GATEWAY_URL=
# RENDER_AGENT_URL=
# DATA_MANAGEMENT_API_URL=
# GATEWAY_SCHEMA_URL=
# DATA_MANAGEMENT_SCHEMA_URL=
# AGENT_SCHEMA_URL=
REINDEX_SERVICE_URL=http://vecinita-scraper-ms:8020/jobs
REINDEX_TRIGGER_TOKEN=
REINDEX_CRON_SCHEDULE=0 2 * * 0
SCRAPER_REINDEX_CLEAN=false
SCRAPER_REINDEX_VERBOSE=false

### OPTIONAL PROFILE: modal-runtime
MODAL_API_PROFILE=vecinita
# Preferred runtime credentials for routing-authenticated Modal endpoints
# like vecinita-model and vecinita-embedding.
MODAL_API_PROXY_KEY=
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
# CLI/deploy credentials. These remain valid fallbacks when runtime routing
# credentials are not configured separately.
MODAL_API_TOKEN_ID=
MODAL_API_TOKEN_SECRET=
# Legacy names still honored by local compose and service repos.
MODAL_AUTH_KEY=
MODAL_AUTH_SECRET=
EMBEDDING_SERVICE_AUTH_TOKEN=
MODAL_EMBEDDING_SERVICE_AUTH_TOKEN=

### OPTIONAL PROFILE: gateway-admin
GATEWAY_PORT=8004
DEV_ADMIN_ENABLED=true
DEV_ADMIN_BEARER_TOKEN=

### OPTIONAL PROFILE: search-edge
DB_SEARCH_EDGE_FUNCTION=search-similar-documents
DB_SEARCH_EDGE_TIMEOUT=12
DB_SEARCH_EDGE_URL=
DB_SEARCH_FORCE_SQL_FALLBACK=false
DB_SEARCH_TRY_TEXT_WRAPPER=false

### OPTIONAL PROFILE: deploy-hooks-and-tooling
CODECOV_TOKEN=
GCLOUD_API_KEY=
GCLOUD_PROJECT_NUMBER=
GCLOUD_PROJECT_ID=
RENDER_VECINITA_EMBEDDING_DEPLOY_HOOK=
RENDER_VECINITA_AGENT_DEPLOY_HOOK=
RENDER_VECINITA_FRONTEND_DEPLOY_HOOK=

