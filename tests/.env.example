# E2E and Integration Test Configuration

## Service URLs
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

## Test Configuration
SKIP_E2E=false                      # Set to true to skip E2E tests
SKIP_INTEGRATION=false              # Set to true to skip integration tests
PLAYWRIGHT_HEADLESS=true            # Set to false to see browser during E2E tests
API_TIMEOUT=10                      # Timeout for API calls in seconds
E2E_TIMEOUT=30                      # Timeout for E2E tests in seconds

## Optional: Playwright Configuration
PLAYWRIGHT_DEBUG=false              # Enable Playwright debug mode
PLAYWRIGHT_SLOWMO=0                 # Slow down Playwright by n milliseconds
