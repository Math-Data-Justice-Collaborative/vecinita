# Modal — vecinita workspace secrets (EXAMPLE / placeholders only)
#
# Best practices (Modal):
#   - Store runtime config in Modal Secrets, not in app source (see modal.com/docs/guide/secrets).
#   - Deploy to workspace `vecinita`, environment `main` (default).
#   - Use `sync_modal_secret.sh --merge --apply` to update keys without dropping existing ones.
#     (`modal secret create --force` REPLACES the whole secret — prefer --merge in production.)
#   - CI/CD: deploy-modal.yml syncs this secret from GitHub Actions secrets before deploy.
#   - DATABASE_URL is forbidden on Modal (ADR-007) — DO internal-write-api holds Postgres.
#
# Dashboard: https://modal.com/secrets/vecinita/main/create?secret_name=vecinita-data-management
#
#   set -a && source prod.env && set +a
#   modal profile activate vecinita
#   bash scripts/deploy/sync_modal_secret.sh --merge --apply
#
# Verify: bash scripts/deploy/verify_secrets.sh
# Deploy:  bash scripts/deploy/modal.sh  (or CI Deploy Modal workflow on main)
#
# Matrix: docs/staging-secrets-matrix.md §Modal
# NEVER commit real secrets to git.

# ---------------------------------------------------------------------------
# vecinita-data-management  (Modal secret: vecinita-data-management)
# Used by: infra/modal/data_management_app.py — ASGI /jobs + ingest workers
# ---------------------------------------------------------------------------

# Upstream Modal apps (deploy embedding + llm first; copy URLs from deploy output)
VECINITA_MODAL_EMBED_URL=https://vecinita--vecinita-embedding-embedding-api.modal.run
VECINITA_MODAL_LLM_URL=https://vecinita--vecinita-llm-fastapi-app.modal.run

# DigitalOcean internal write API (sole DATABASE_URL holder — ADR-007)
VECINITA_INTERNAL_WRITE_URL=https://vecinita-internal-write-api-<id>.ondigitalocean.app
VECINITA_INTERNAL_API_KEY=<same-as-do-VECINITA_INTERNAL_API_KEY>

# Edge proxy + browser CORS (must match admin frontend origin + DO VITE_VECINITA_MODAL_PROXY_KEY)
VECINITA_MODAL_PROXY_KEY=<same-as-VITE_VECINITA_MODAL_PROXY_KEY>
VECINITA_CORS_ORIGINS=https://vecinita-admin-frontend-<id>.ondigitalocean.app,https://vecinita-chat-rag-frontend-<id>.ondigitalocean.app

# EV-005 F34 — Supabase JWT verification on /jobs* (ES256/JWKS; ADR-028)
SUPABASE_URL=https://<project-ref>.supabase.co
VECINITA_AUTH_REQUIRED=true
# SUPABASE_JWT_AUD=authenticated

# EV-006 F35 — Supabase Admin API for /admin/users* (ADR-030).
# Server-side only; sole holder of SUPABASE_SECRET_KEY among running services.
SUPABASE_SECRET_KEY=sb_secret_<your-secret-key>

# EV-007 F35 — GoTrue redirect_to for invite / resend / recovery (ADR-032 §2)
VECINITA_ADMIN_FRONTEND_URL=https://vecinita-admin-frontend-<id>.ondigitalocean.app

# EV-006 F35 — Resend REST test-send (POST /admin/email/test; TP-S005-22)
# Same API key as SUPABASE_SMTP_PASS — see infra/resend/.env.example
RESEND_API_KEY=re_<resend-api-key>
RESEND_SENDER_EMAIL=noreply@<verified-resend-domain>

# Optional ingest / tagging tuning
# VECINITA_LLM_TAG_MAX_TOKENS=128
# VECINITA_TAG_SEED_PATH=data/fixtures/tags/seed_tags.json

# ---------------------------------------------------------------------------
# Operator-only (NOT in Modal secret — prod.env for bootstrap scripts)
# ---------------------------------------------------------------------------
# SUPABASE_ADMIN_EMAIL=admin@example.com
# SUPABASE_ADMIN_PASSWORD=<strong-password>
# Used by: uv run python scripts/seed_first_admin.py

# ---------------------------------------------------------------------------
# CI/CD only (GitHub Actions — NOT pushed to Modal secret)
# Modal continuous deployment: https://modal.com/docs/guide/continuous-deployment
# ---------------------------------------------------------------------------
# MODAL_TOKEN_ID=ak-<token-id>
# MODAL_TOKEN_SECRET=as-<token-secret>

# ---------------------------------------------------------------------------
# vecinita-llm  (Modal secret: vecinita-llm)
# Used by: infra/modal/llm_app.py — ASGI proxy auth on /models/ollama*
# Sync: bash scripts/deploy/sync_llm_secret.sh --apply
# ---------------------------------------------------------------------------
# VECINITA_MODAL_PROXY_KEY=<same-as-do-VECINITA_MODAL_PROXY_KEY>

# ---------------------------------------------------------------------------
# vecinita-embedding / vecinita-llm weights — Modal volumes (no Postgres secrets)
# Stage weights: ./scripts/stage_modal_weights.sh
# Playground default tag: modal run infra/modal/llm_app.py::stage_default_model
# ---------------------------------------------------------------------------
