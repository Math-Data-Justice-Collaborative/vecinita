# GitHub Actions CI/CD secrets — EXAMPLE (placeholders only; never commit real values)
#
# These are the repository secrets consumed by the GitHub Actions workflows.
# Add them under: GitHub repo -> Settings -> Secrets and variables -> Actions -> New repository secret
# Or via the gh CLI:  gh secret set MODAL_TOKEN_ID --body '<value>'
#
# This file documents WHICH keys are needed. Real values live in your local prod.env
# (gitignored) and in GitHub's encrypted secrets store — not here.

# ---------------------------------------------------------------------------
# REQUIRED — Modal CI/CD (deploy-preflight.yml + deploy-modal.yml)
# ---------------------------------------------------------------------------
# Modal API token for the `vecinita` workspace. Create at https://modal.com/settings/tokens
# Token auth (no named ~/.modal.toml profile) per:
#   https://modal.com/docs/guide/continuous-deployment
# Used by:
#   - deploy-preflight.yml  -> modal-secrets job (verify_secrets.sh)
#   - deploy-modal.yml      -> deploys embedding (CPU), data-management, llm (GPU)
MODAL_TOKEN_ID=<your-modal-token-id>          # starts with "ak-"
MODAL_TOKEN_SECRET=<your-modal-token-secret>  # starts with "as-"

# ---------------------------------------------------------------------------
# REQUIRED — DigitalOcean CD (deploy-digitalocean.yml)
# ---------------------------------------------------------------------------
# DO App Platform auto-deploys on push to `main` via `deploy_on_push: true` in
# infra/do/*.yaml. deploy-digitalocean.yml is a deterministic backstop that runs
# after CI succeeds on `main` and force-deploys all four apps via
# scripts/deploy/do_apps.py, so a dropped GitHub -> DO push webhook never leaves
# `main` undeployed. Create a token with Apps read/write scope at
#   https://cloud.digitalocean.com/account/api/tokens
DIGITALOCEAN_TOKEN=<your-do-api-token>         # starts with "dop_v1_"

# ---------------------------------------------------------------------------
# NOT GitHub secrets (do NOT add these to Actions)
# ---------------------------------------------------------------------------
# - DATABASE_URL          : CI uses an ephemeral Postgres service container; production
#                           DB string lives in DigitalOcean app secrets. Forbidden on Modal (ADR-007).
# - VECINITA_* app/runtime : set in DigitalOcean app secrets and the Modal
#                           `vecinita-data-management` secret — see docs/staging-secrets-matrix.md.
