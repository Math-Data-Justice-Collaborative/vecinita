# Resend — email delivery (EXAMPLE / placeholders only)
#
# Vecinita uses Resend in TWO paths (same API key, different runtimes):
#
#   1. Supabase Auth SMTP  — invite / recovery / magic-link emails
#      Key name: SUPABASE_SMTP_PASS (GitHub Actions secret)
#      Applied by: supabase config push → [auth.email.smtp] pass = env(SUPABASE_SMTP_PASS)
#      Host: smtp.resend.com:465, user "resend" (see supabase/config.toml)
#
#   2. Modal admin test-send — POST /admin/email/test (in-app button)
#      Key name: RESEND_API_KEY (Modal secret vecinita-data-management)
#      Sender: RESEND_SENDER_EMAIL (must match config.toml admin_email)
#
# Best practices (Resend + Supabase):
#   - Verify your sending domain in Resend (SPF + DKIM) BEFORE production.
#   - Use one API key per environment; rotate via Resend dashboard → update prod.env → sync.
#   - Never commit re_* keys; store in prod.env and push via sync scripts.
#   - Sender address MUST match supabase/config.toml [auth.email.smtp] admin_email.
#
# Push to all three stores from prod.env:
#   bash scripts/deploy/sync_github_secrets.sh --apply   # → SUPABASE_SMTP_PASS on GitHub
#   bash scripts/supabase/ci_sync.sh sync-production     # → config push (CI on main)
#   bash scripts/deploy/sync_modal_secret.sh --merge --apply  # → RESEND_* on Modal
#
# Template: infra/resend/.env.example
# Matrix: docs/staging-secrets-matrix.md §EV-006
# NEVER commit real secrets to git.

# ---------------------------------------------------------------------------
# Resend API key (re_...) — same value in GitHub + Modal
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_<resend-api-key>

# Verified sender on your Resend domain (= supabase/config.toml admin_email)
RESEND_SENDER_EMAIL=noreply@josephcmcg.com

# Alternative name used by Supabase CLI / GitHub Actions (same value as RESEND_API_KEY)
# sync_github_secrets.sh maps RESEND_API_KEY → SUPABASE_SMTP_PASS when pushing to GitHub.
SUPABASE_SMTP_PASS=re_<resend-api-key>
