# deploy/gcp/.env.example
# Copy to backend/.env on the VM:
#   cp deploy/gcp/.env.example backend/.env

# -----------------------------
# Core runtime
# -----------------------------
PORT=8000
GATEWAY_PORT=8004

# -----------------------------
# Supabase / Postgres
# -----------------------------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# -----------------------------
# Agent + LLM
# -----------------------------
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=llama3.1:8b

# Optional fallback providers
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# -----------------------------
# Embedding service
# -----------------------------
EMBEDDING_SERVICE_URL=https://YOUR_EMBED_SERVICE.run.app
EMBEDDING_SERVICE_AUTH_TOKEN=

# -----------------------------
# Chroma (container-to-container)
# -----------------------------
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_SSL=false
CHROMA_COLLECTION_CHUNKS=vecinita_chunks
CHROMA_COLLECTION_SOURCES=vecinita_sources
CHROMA_COLLECTION_QUEUE=vecinita_queue

# -----------------------------
# Gateway/admin + uploads
# -----------------------------
DEV_ADMIN_ENABLED=false
DEV_ADMIN_BEARER_TOKEN=
SUPABASE_UPLOADS_BUCKET=documents

# -----------------------------
# Optional observability/guardrails
# -----------------------------
GUARDRAILS_ENABLED=true
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
